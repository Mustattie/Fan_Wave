# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env.*
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Maestro per-run debug output (logs + commands JSON). Committed scenario
# screenshots, if any, live elsewhere; this directory is recreated each run.
qa/maestro/output/

# Play Store service account key (used by eas submit). Sensitive credentials —
# never commit.
play-store-key.json
